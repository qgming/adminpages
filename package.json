{
  "name": "tusi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p functions/tsconfig.json --noEmit",
    "pages:dev": "wrangler pages dev dist --kv=KV_BINDING",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
