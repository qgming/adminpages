    "@fontsource-variable/geist": "^5.2.8",
    "@types/dompurify": "^3.0.5",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.5",
    "lucide-react": "^0.453.0",
    "marked": "^18.0.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.1.1",
    "shadcn": "^4.6.0",
